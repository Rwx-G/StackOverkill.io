# StackOverkill.io - Environment Variables
# Copy this file to .env and fill in the values

# ===================
# Frontend (Next.js)
# ===================

# Public base URL (used for OG images, canonical URLs)
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# Backend URL for server-side API proxy (internal Docker network in production)
BACKEND_URL=http://localhost:3001

# ===================
# Backend (Express)
# ===================

# Server port
PORT=3001

# Environment
NODE_ENV=development

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000

# Data directory (leaderboard storage)
DATA_DIR=./data

# Log level (debug, info, warn, error)
LOG_LEVEL=info
